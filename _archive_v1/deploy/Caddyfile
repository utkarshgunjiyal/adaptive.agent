# Runner.ai — production reverse proxy (Phase 42B).
#
# Caddy fronts the whole stack on a single VM and terminates HTTPS automatically
# (ACME). It is the ONLY publicly-exposed service; backend, frontend, and all
# infrastructure stay on the internal Docker network.
#
# Substituted at runtime from the environment:
#   {$DOMAIN}
#   {$TLS_EMAIL}
#   {$BACKEND_UPSTREAM}
#   {$FRONTEND_UPSTREAM}
#
# Routing:
#   /agent/*, /health/*, /chat/*, /documents/*, /jobs/*,
#   /memory/*, /threads, /threads/*, /integrations,
#   /integrations/* -> backend
#
#   everything else -> frontend SPA
#
#   /metrics -> 404
#
# SSE:
#   POST /agent/run/stream is proxied with buffering disabled.

{
	email {$TLS_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		X-Frame-Options "DENY"
		-Server
	}

	# Never expose Prometheus metrics publicly.
	handle /metrics* {
		respond 404
	}

	# Optional private-demo authentication.
	import auth.conf

	# Backend API routes.
	@backend path \
		/agent \
		/agent/* \
		/health \
		/health/* \
		/chat \
		/chat/* \
		/documents \
		/documents/* \
		/jobs \
		/jobs/* \
		/memory \
		/memory/* \
		/threads \
		/threads/* \
		/integrations \
		/integrations/*

	handle @backend {
		reverse_proxy {$BACKEND_UPSTREAM} {
			flush_interval -1

			transport http {
				keepalive 120s
				response_header_timeout 0
			}
		}
	}

	# Frontend SPA.
	handle {
		reverse_proxy {$FRONTEND_UPSTREAM}
	}

	log {
		output stdout
		format console
	}
}